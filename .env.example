# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TWEETS=raw-tweets
KAFKA_TOPIC_PROCESSED=processed-tweets
KAFKA_TOPIC_ANOMALIES=anomalies
KAFKA_TOPIC_ALERTS=alerts

# Elasticsearch Configuration
ELASTICSEARCH_HOST=localhost:9200
ELASTICSEARCH_INDEX_TWEETS=tweets
ELASTICSEARCH_INDEX_ANOMALIES=anomalies

# Grafana Configuration
GRAFANA_URL=http://localhost:3000
#GRAFANA_USER=admin
#GRAFANA_PASSWORD=admin
#GRAFANA_API_KEY=your_api_key_here

# Tweet Simulator Configuration
TWEET_RATE=60
SIMULATION_MODE=trade_war_escalation
LANGUAGE_MIX=en:0.7,fr:0.3

# Spark Configuration
SPARK_MASTER_URL=spark://localhost:7077
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# Alert System Configuration
ALERT_THRESHOLD_SENTIMENT=0.8
ALERT_THRESHOLD_VOLUME=100
ALERT_EMAIL_ENABLED=false